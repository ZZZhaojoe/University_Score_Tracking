<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.control.Button?>

<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.ProgressBar?>


<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.university_score_tracking.HelloController"
      alignment="CENTER"
      spacing="10">

    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <TextField fx:id="CourseField" promptText="Course Name"/>

    <ComboBox fx:id="GradeBox" promptText="Grade"/>

    <TextField fx:id="UnitField" promptText="Unit"/>

    <ComboBox fx:id="semesterBox" promptText="Semester"/>

    <Button text="Add Course" onAction="#addCourse"/>

    <Button text="Remove Course" onAction="#removeCourse"/>

    <Button text="Save Course" onAction="#saveCourse"/>

    <Button text="Load Course" onAction="#loadCourse"/>

    <Label text="Degree Progress"/>

    <ProgressBar
            fx:id="progressBar"
            progress="0.0"
            minWidth="300"
            prefWidth="300"
            maxWidth="300"
            minHeight="20"
            prefHeight="20"
            style="-fx-accent: #2e8b57;"/>

    <TableView fx:id="courseTable">
            <columns>
                <TableColumn
                        fx:id="semesterCol"
                        text="Semester"/>

                <TableColumn
                        fx:id="CourseCol"
                        text="Courses"/>

                <TableColumn
                        fx:id="GradeCol"
                        text="Grade"/>

                <TableColumn
                        fx:id="UnitCol"
                        text="Unit"/>

            </columns>
    </TableView>

    <TableView fx:id="requirementTable">
        <columns>
            <TableColumn
                fx:id="requiredCourseCol"
                text = "Required Course"/>

            <TableColumn
                    fx:id="completedCourse"
                    text = "Course Completed"/>
        </columns>
    </TableView>

    <Label fx:id="gpaLabel" text="Current GPA: 0.00"/>

</VBox>
