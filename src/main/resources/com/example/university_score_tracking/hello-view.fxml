<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.control.Button?>

<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ListView?>
<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.university_score_tracking.HelloController"
      alignment="CENTER"
      spacing="10">

    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <TextField fx:id="CourseField" promptText="Course Name"/>

    <TextField fx:id="GradeField" promptText="Grade"/>

    <TextField fx:id="UnitField" promptText="Unit"/>

    <Button text="Add Course" onAction="#addCourse"/>

    <Button text="Remove Course" onAction="#removeCourse"/>

    <Button text="Save Course" onAction="#saveCourse"/>

    <Button text="Load Course" onAction="#loadCourse"/>

    <ListView fx:id="courseList" />

    <Label fx:id="gpaLabel" text="Current GPA: 0.00"/>

</VBox>
